{
  "$id": "https://github.com/BlockScience/bdp-lib/tree/main/src/bdp_lib/schemas/system.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "System Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ID": {
      "type": "string",
      "title": "ID",
      "description": "A unique identifier for the system."
    },
    "Name": {
      "type": "string",
      "title": "Name",
      "description": "The name of the system."
    },
    "Description": {
      "type": "string",
      "title": "Description",
      "description": "A description of the system."
    },
    "ConcreteBlocks": {
      "type": "array",
      "title": "ConcreteBlocks",
      "description": "A list of concrete block IDs that are part of the system.",
      "items": {
        "type": "string"
      }
    },
    "Wires": {
      "type": "array",
      "title": "Wires",
      "description": "A list of wire IDs that are part of the system.",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "ID",
    "Name",
    "ConcreteBlocks",
    "Wires"
  ]
}