{"$id": "https://github.com/BlockScience/bdp-lib/tree/main/src/bdp_lib/schemas/block.schema.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Block Schema",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "ID": {
        "type": "string"
      },
      "Name": {
        "type": "string"
      },
      "Description": {
        "type": "string"
      },
      "Domain": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "Codomain": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
